#!/bin/bash
# Clippy's Revenge — launcher wrapper
#
# Resolves its own install location, sets PYTHONPATH, and execs the launcher.

set -euo pipefail

resolve_path() {
    local target="$1"
    while [ -L "$target" ]; do
        local dir="$(cd "$(dirname "$target")" && pwd)"
        target="$(readlink "$target")"
        [[ "$target" != /* ]] && target="$dir/$target"
    done
    echo "$(cd "$(dirname "$target")" && pwd)"
}
SCRIPT_DIR="$(resolve_path "$0")"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

export PYTHONPATH="${PROJECT_ROOT}${PYTHONPATH:+:$PYTHONPATH}"

exec python3 -m clippy.launcher "$@"
